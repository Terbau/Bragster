// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  avatarUrl String?
  admin     Boolean  @default(false)

  receipts           Receipt[]
  payments           SmartReceiptPayment[]
  smartReceipts      SmartReceipt[]
  createdInviteLinks SmartReceiptInviteLink[]
}

// All below represents a receipt and its items. They are the models for the
// "smart receipt" / "collective receipt" feature. They are just to represent
// the data structure and relationships of receipts. It may be used for more
// features in the future.

model Receipt {
  id           String    @id @default(uuid())
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  merchantName String
  receiptType  String?
  receiptDate  DateTime?
  totalPrice   Float
  currencyCode String?
  createdBy    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemGroups    ReceiptItemGroup[]
  smartReceipts SmartReceipt[]

  @@index([userId])
}

model ReceiptItemGroup {
  id           String   @id @default(uuid())
  receiptId    String
  description  String
  price        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // quantity could be a decimal number
  quantity     Float
  quantityUnit String?
  unitPrice    Float

  receipt      Receipt                       @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  items        ReceiptItem[]
  translations ReceiptItemGroupTranslation[]

  @@index([receiptId])
}

model ReceiptItem {
  id          String   @id @default(uuid())
  itemGroupId String
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itemGroup          ReceiptItemGroup           @relation(fields: [itemGroupId], references: [id], onDelete: Cascade)
  supplements        ReceiptItemSupplement[]
  smartPayments      SmartReceiptPayment[]
  guestSmartPayments SmartReceiptGuestPayment[]

  @@index([itemGroupId])
}

model ReceiptItemSupplement {
  id          String   @id @default(uuid())
  itemId      String
  description String
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item         ReceiptItem                        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  translations ReceiptItemSupplementTranslation[]

  @@index([itemId])
}

model ReceiptItemGroupTranslation {
  id          String @id @default(uuid())
  itemGroupId String

  label                  String
  description            String
  language               String
  lightModeLabelHexColor String
  darkModeLabelHexColor  String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  itemGroup ReceiptItemGroup @relation(fields: [itemGroupId], references: [id], onDelete: Cascade)

  @@index([itemGroupId])
}

model ReceiptItemSupplementTranslation {
  id           String @id @default(uuid())
  supplementId String

  label                  String
  description            String
  language               String
  lightModeLabelHexColor String
  darkModeLabelHexColor  String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  supplement ReceiptItemSupplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@index([supplementId])
}

// "Collective receipt" / "Smart receipt" is for the feature where multiple users
// can share a receipt and split the payment in a crowd-funded manner.

enum SmartReceiptAllowedPaymentEditor {
  OWNER
  AUTHENTICATED_USERS
  GUESTS
  ANYONE
}

model SmartReceiptGuest {
  id             String   @id @default(uuid())
  smartReceiptId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  smartReceipt SmartReceipt               @relation(fields: [smartReceiptId], references: [id], onDelete: Cascade)
  payments     SmartReceiptGuestPayment[]

  @@unique([smartReceiptId, name])
  @@index([smartReceiptId])
}

model SmartReceipt {
  id                    String                           @id @default(uuid())
  receiptId             String
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  updatedTotalPrice     Float?
  updatedCurrencyCode   String?
  allowedPaymentEditors SmartReceiptAllowedPaymentEditor @default(OWNER)

  receipt       Receipt                    @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  users         User[] // The users who are a part of this smart receipt
  guests        SmartReceiptGuest[]
  payments      SmartReceiptPayment[]
  guestPayments SmartReceiptGuestPayment[]
  inviteLinks   SmartReceiptInviteLink[]

  @@index([receiptId])
}

model SmartReceiptPayment {
  id             String   @id @default(uuid())
  userId         String
  smartReceiptId String
  receiptItemId  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  smartReceipt SmartReceipt? @relation(fields: [smartReceiptId], references: [id], onDelete: Cascade)
  item         ReceiptItem   @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)
}

model SmartReceiptGuestPayment {
  id             String   @id @default(uuid())
  guestId        String
  smartReceiptId String
  receiptItemId  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  guest        SmartReceiptGuest @relation(fields: [guestId], references: [id], onDelete: Cascade)
  smartReceipt SmartReceipt?     @relation(fields: [smartReceiptId], references: [id], onDelete: Cascade)
  item         ReceiptItem       @relation(fields: [receiptItemId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

model SmartReceiptInviteLink {
  id             String    @id @default(uuid())
  smartReceiptId String
  createdById    String
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  smartReceipt SmartReceipt @relation(fields: [smartReceiptId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([smartReceiptId])
}
